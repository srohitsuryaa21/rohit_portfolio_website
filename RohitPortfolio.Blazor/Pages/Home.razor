@page "/"
@inject IJSRuntime JS

<PageTitle>Rohit Suryaa Saravanan — Data Scientist & Software Engineer</PageTitle>

<a class="skip-link" href="#main-content">Skip to content</a>
<div class="scroll-progress" aria-hidden="true"><span></span></div>
<div class="cursor-glow" aria-hidden="true"></div>

<nav aria-label="Primary navigation">
    <a class="nav-logo" href="#hero" aria-label="Rohit Suryaa Saravanan — Home">
        <span>R</span><span class="logo-dot"></span><span>S</span>
    </a>
    <ul class="nav-links @(menuOpen ? "open" : "")">
        @foreach (var item in NavItems)
        {
            <li><a href="#@item.Id" data-nav="@item.Id" @onclick="CloseMenu">@T(item.En, item.De)</a></li>
        }
        <li><a href="/blog" @onclick="CloseMenu">@T("Blog", "Blog")</a></li>
    </ul>
    <div class="nav-actions">
        <button class="icon-button command-trigger" @onclick="OpenCommandPalette" aria-label="Open command menu">
            <span>⌘</span><kbd>K</kbd>
        </button>
        <button class="icon-button" @onclick="ToggleLanguage" aria-label="Change language">@(isGerman ? "EN" : "DE")</button>
        <button class="icon-button" @onclick="ToggleTheme" aria-label="Change color theme">@(isDark ? "☀" : "◐")</button>
        <button class="mobile-menu-button" @onclick="ToggleMenu" aria-label="Toggle navigation" aria-expanded="@menuOpen">
            <span></span><span></span>
        </button>
    </div>
</nav>

<main id="main-content">
    <section id="hero" data-section>
        <div class="hero-noise"></div>
        <div class="hero-copy reveal">
            <div class="eyebrow"><i></i>@T("Based in Fulda · Open to opportunities", "In Fulda · Offen für Möglichkeiten")</div>
            <h1>
                @T("I build reliable software", "Ich entwickle zuverlässige Software")
                <span class="outline-text">@T("and intelligent data systems.", "und intelligente Datensysteme.")</span>
            </h1>
            <p class="hero-sub">
                @T("Software Developer and Data Scientist with 1+ year of professional experience building backend systems, data products, machine learning solutions, and modern .NET applications.",
                   "Softwareentwickler und Data Scientist mit über einem Jahr Berufserfahrung in Backend-Systemen, Datenprodukten, Machine Learning und modernen .NET-Anwendungen.")
            </p>
            <div class="hero-cta">
                <a href="#work" class="btn-primary magnetic">@T("Explore selected work", "Projekte entdecken") <span>↘</span></a>
                <a href="mailto:Rohitsuryaas21@gmail.com" class="btn-quiet">@T("Start a conversation", "Kontakt aufnehmen") ↗</a>
            </div>
            <a class="hero-nudge magnetic" href="#lab">
                <span></span>
                @T("New: scan my fit for your open role", "Neu: Rollen-Fit für Ihre Position prüfen")
            </a>
            <div class="hero-meta">
                <span><strong>02</strong> IEEE publications</span>
                <span><strong>04+</strong> production projects</span>
                <span><strong>DE / EN</strong> communication</span>
            </div>
        </div>

        <div class="hero-stage reveal" data-tilt>
            <div class="stage-chrome">
                <span></span><span></span><span></span>
                <small>rohit://intelligence-lab</small>
            </div>
            <div class="stage-grid">
                <div class="portrait-panel">
                    <div class="portrait-frame">
                        <img src="images/rohit.jpg" alt="Portrait of Rohit Suryaa Saravanan" />
                        <div class="scan-line"></div>
                    </div>
                    <div class="status-line"><i></i> SYSTEM ONLINE</div>
                </div>
                <div class="data-panel">
                    <div class="data-label">MODEL PERFORMANCE</div>
                    <strong class="counter" data-count="96">0</strong><b>%</b>
                    <svg viewBox="0 0 280 95" role="img" aria-label="Rising model performance chart">
                        <defs><linearGradient id="chartFill" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="currentColor" stop-opacity=".35"/><stop offset="1" stop-color="currentColor" stop-opacity="0"/></linearGradient></defs>
                        <path class="chart-area" d="M0,82 C30,76 43,66 67,70 S107,45 132,54 S173,32 197,38 S235,13 280,8 L280,95 L0,95Z"/>
                        <path class="chart-line" d="M0,82 C30,76 43,66 67,70 S107,45 132,54 S173,32 197,38 S235,13 280,8"/>
                    </svg>
                    <div class="data-row"><span>ERROR RATE</span><strong>2.3%</strong></div>
                    <div class="data-row"><span>POWER GAIN</span><strong>+21%</strong></div>
                </div>
            </div>
            <div class="floating-chip chip-one">Python</div>
            <div class="floating-chip chip-two">C# / .NET</div>
            <div class="floating-chip chip-three">ML Systems</div>
        </div>
        <a class="scroll-cue" href="#about"><span></span>@T("Scroll to explore", "Scrollen zum Entdecken")</a>
    </section>

    <section id="about" class="section-shell" data-section>
        <div class="section-number">01</div>
        <div class="section-intro reveal">
            <div class="section-label">@T("Positioning", "Positionierung")</div>
            <h2>@T("Engineering discipline.", "Technische Disziplin.")<br /><em>@T("Research curiosity.", "Neugier in der Forschung.")</em></h2>
        </div>
        <div class="about-layout">
            <div class="about-statement reveal">
                <p>@T(
                    "I work where data science meets software engineering. That means I care about the model, but also the API around it, the interface people use, the deployment pipeline, and whether the result creates measurable value.",
                    "Ich arbeite an der Schnittstelle von Data Science und Software Engineering. Das bedeutet: Nicht nur das Modell zählt, sondern auch API, Benutzeroberfläche, Deployment und messbarer Nutzen.")
                </p>
                <p>@T(
                    "Currently pursuing an MSc in Data Science at Hochschule Fulda after building enterprise systems for a US cybersecurity startup.",
                    "Aktuell absolviere ich den M.Sc. Data Science an der Hochschule Fulda, nachdem ich Enterprise-Systeme für ein US-Cybersecurity-Startup entwickelt habe.")
                </p>
            </div>
            <div class="principles reveal">
                @foreach (var principle in Principles)
                {
                    <article><span>@principle.Number</span><div><h3>@T(principle.En, principle.De)</h3><p>@T(principle.BodyEn, principle.BodyDe)</p></div></article>
                }
            </div>
        </div>
    </section>

    <section id="work" class="section-shell work-section" data-section>
        <div class="section-number">02</div>
        <div class="section-intro reveal">
            <div>
                <div class="section-label">@T("Selected work", "Ausgewählte Projekte")</div>
                <h2>@T("Proof, not promises.", "Belege statt Versprechen.")</h2>
            </div>
            <div class="filter-tabs" role="group" aria-label="Project filters">
                @foreach (var filter in ProjectFilters)
                {
                    <button class="@(activeFilter == filter.Key ? "active" : "")" @onclick="() => SetProjectFilter(filter.Key)">@T(filter.En, filter.De)</button>
                }
            </div>
        </div>
        @{
            var visibleProjects = FilteredProjects.ToArray();
            var activeProject = visibleProjects.Length == 0 ? null : visibleProjects[Math.Clamp(activeProjectIndex, 0, visibleProjects.Length - 1)];
        }
        <div class="project-stack-shell reveal">
            <div class="project-stack-topline">
                <div>
                    <span>@T("Drag the project stack", "Projektstapel ziehen")</span>
                    <strong>@(activeProject?.TitleEn ?? T("No project", "Kein Projekt"))</strong>
                </div>
                <div class="project-stack-actions">
                    @if (!string.IsNullOrWhiteSpace(activeProject?.GitHubUrl))
                    {
                        <a class="project-stack-link" target="_blank" rel="noopener" href="@activeProject.GitHubUrl">GitHub repo -></a>
                    }
                    <div class="project-stack-controls" aria-label="Project browser controls">
                        <button type="button" @onclick="() => MoveProject(-1)" aria-label="Previous project">‹</button>
                        <span>@(visibleProjects.Length == 0 ? "0/0" : $"{activeProjectIndex + 1}/{visibleProjects.Length}")</span>
                        <button type="button" @onclick="() => MoveProject(1)" aria-label="Next project">›</button>
                    </div>
                </div>
            </div>
            <div class="project-stack @(isProjectDragging ? "dragging" : "")"
                 data-project-stack
                 tabindex="0"
                 aria-label="Draggable project stack"
                 @onpointerdown="StartProjectDrag"
                 @onpointermove="MoveProjectDrag"
                 @onpointerup="EndProjectDrag"
                 @onpointerleave="CancelProjectDrag"
                 style="--drag:@projectDragOffset">
                @foreach (var item in visibleProjects.Select((Project, Index) => new { Project, Index }))
                {
                    var offset = GetProjectOffset(item.Index, visibleProjects.Length);
                    var distance = Math.Abs(offset);
                    var cardState = offset == 0 ? "active" : offset < 0 ? "is-left" : "is-right";
                    var hiddenState = distance > 2 ? "is-hidden" : "";
                    <div class="project-stack-card @cardState @hiddenState"
                         style="--offset:@offset; --distance:@distance; z-index:@(80 - distance);"
                         @onclick="() => SetActiveProject(item.Index)"
                         @key="item.Project.Number">
                        <ProjectCard Project="item.Project" German="isGerman" />
                    </div>
                }
            </div>
            <div class="project-stack-dots" aria-label="Project stack position">
                @foreach (var item in visibleProjects.Select((Project, Index) => new { Project, Index }))
                {
                    <button type="button"
                            class="@(item.Index == activeProjectIndex ? "active" : "")"
                            @onclick="() => SetActiveProject(item.Index)"
                            aria-label="@($"Open project {item.Index + 1}")"></button>
                }
            </div>
        </div>
    </section>

    <section id="lab" class="section-shell lab-section" data-section>
        <div class="section-number">03</div>
        <div class="section-intro reveal">
            <div class="section-label">@T("Role fit scanner", "Rollen-Fit-Scanner")</div>
            <h2>@T("Pick a role.", "Rolle auswählen.")<br /><em>@T("See the proof.", "Belege sehen.")</em></h2>
        </div>
        <div class="role-scanner reveal">
            <div class="scanner-sidebar">
                <div class="control-heading">
                    <span>ROLE SCANNER / 2026</span>
                    <i>@T("LIVE FIT MAP", "LIVE-FIT-MAP")</i>
                </div>
                <p>@T(
                    "Recruiters scan fast. Choose a target path and the portfolio reorganizes around the evidence that matters: skills, outcomes, projects, and delivery style.",
                    "Recruiter scannen schnell. Wählen Sie eine Zielrolle und das Portfolio zeigt die relevanten Belege: Skills, Ergebnisse, Projekte und Arbeitsweise.")</p>
                <div class="role-options" role="list" aria-label="Target role options">
                    @foreach (var role in RoleFits)
                    {
                        <button class="@(selectedRole == role.Key ? "active" : "")" @onclick="() => SelectRole(role.Key)" role="listitem">
                            <span>@role.Icon</span>
                            <b>@T(role.TitleEn, role.TitleDe)</b>
                            <small>@T(role.SignalEn, role.SignalDe)</small>
                        </button>
                    }
                </div>
            </div>
            <div class="scanner-output">
                <div class="fit-topline">
                    <div class="fit-orbit" style="--value:@SelectedRole.FitScore">
                        <div><strong>@SelectedRole.FitScore%</strong><span>@T("ROLE FIT", "ROLLEN-FIT")</span></div>
                    </div>
                    <div class="fit-summary">
                        <span>@T("Hiring signal", "Hiring-Signal")</span>
                        <h3>@T(SelectedRole.HeadlineEn, SelectedRole.HeadlineDe)</h3>
                        <p>@T(SelectedRole.BodyEn, SelectedRole.BodyDe)</p>
                    </div>
                </div>
                <div class="fit-evidence">
                    @foreach (var evidence in SelectedEvidence)
                    {
                        <article>
                            <span>0@(Array.IndexOf(SelectedEvidence, evidence) + 1)</span>
                            <p>@evidence</p>
                        </article>
                    }
                </div>
                <div class="fit-stack">
                    @foreach (var tag in SelectedRole.Stack)
                    {
                        <span>@tag</span>
                    }
                </div>
                <a class="fit-link magnetic" href="#work" @onclick="ApplySelectedRoleFilter">@T("Open matching proof", "Passende Belege öffnen") ↗</a>
            </div>
        </div>
    </section>

    <section id="experience" class="section-shell experience-section" data-section>
        <div class="section-number">04</div>
        <div class="section-intro reveal">
            <div class="section-label">@T("Experience & toolkit", "Erfahrung & Werkzeuge")</div>
            <h2>@T("Built across the stack.", "Über den gesamten Stack.")</h2>
        </div>
        <div class="experience-grid">
            <article class="experience-card reveal">
                <div class="experience-date">2024 — 2025</div>
                <h3>Software Developer</h3>
                <a href="#contact">EigenSecure · USA / Remote ↗</a>
                <p>@T("Built scalable enterprise software for a cybersecurity startup: backend APIs, data workflows, responsive interfaces, and delivery automation in an Agile team.",
                    "Skalierbare Enterprise-Software für ein Cybersecurity-Startup: Backend-APIs, Datenworkflows, responsive Oberflächen und Delivery-Automatisierung.")</p>
                <div class="impact-row"><span>REST APIs</span><span>Enterprise UI</span><span>Agile delivery</span></div>
            </article>
            <div class="tool-cloud reveal">
                @foreach (var skill in Skills)
                {
                    <div class="tool-group">
                        <span>@skill.Label</span>
                        <div>@foreach (var tag in skill.Tags) { <b>@tag</b> }</div>
                    </div>
                }
            </div>
        </div>
    </section>

    <section id="education" class="section-shell education-section" data-section>
        <div class="section-number">05</div>
        <div class="section-intro reveal">
            <div class="section-label">@T("Education & credentials", "Ausbildung & Zertifikate")</div>
            <h2>@T("Always in learning mode.", "Immer im Lernmodus.")</h2>
        </div>
        <div class="education-timeline reveal">
            <article><time>2025 — @T("Present", "Heute")</time><div><h3>MSc Data Science</h3><p>Hochschule Fulda · Germany</p></div><span>01</span></article>
            <article><time>2020 — 2024</time><div><h3>BTech Big Data Computer Science</h3><p>SRM University · Chennai, India</p></div><span>02</span></article>
        </div>
        <div class="credential-marquee" aria-label="Certifications">
            <div>
                @foreach (var cert in Certifications.Concat(Certifications))
                {
                    <span><i>✦</i> @cert</span>
                }
            </div>
        </div>
    </section>

    <section id="contact" class="contact-section" data-section>
        <div class="contact-orb"></div>
        <div class="contact-inner reveal">
            <div class="section-label">@T("Have a problem worth solving?", "Ein Problem, das gelöst werden sollte?")</div>
            <h2>@T("Let’s build something", "Lass uns etwas bauen,")<br /><em>@T("that earns attention.", "das Aufmerksamkeit verdient.")</em></h2>
            <p>@T("Open to C#/.NET software development, backend engineering, data engineering, data science, machine learning, and research opportunities in Germany and beyond.",
                "Offen für C#/.NET-Softwareentwicklung, Backend Engineering, Data Engineering, Data Science, Machine Learning und Forschung in Deutschland und darüber hinaus.")</p>
            <div class="contact-role-list" aria-label="Target roles">
                <span>C# / .NET</span><span>Software Development</span><span>Backend Engineering</span><span>Data & ML</span>
            </div>
            <div class="contact-actions">
                <a href="mailto:Rohitsuryaas21@gmail.com" class="contact-email magnetic">Rohitsuryaas21@gmail.com <span>↗</span></a>
                <button class="copy-button" @onclick="CopyEmail">@(emailCopied ? T("Copied!", "Kopiert!") : T("Copy email", "E-Mail kopieren"))</button>
            </div>
            <div class="social-row">
                <a target="_blank" rel="noopener" href="https://github.com/srohitsuryaa21">GitHub ↗</a>
                <a target="_blank" rel="noopener" href="https://www.linkedin.com/in/rohit-suryaa-saravanan-197b33303/">LinkedIn ↗</a>
            </div>
        </div>
    </section>
</main>

<footer>
    <span>© 2026 Rohit Suryaa Saravanan</span>
    <span>@T("Designed and engineered with C#, Blazor & JavaScript", "Entworfen und entwickelt mit C#, Blazor & JavaScript")</span>
    <a href="#hero">Back to top ↑</a>
</footer>

@if (commandPaletteOpen)
{
    <div class="modal-backdrop command-backdrop" @onclick="CloseCommandPalette">
        <div class="command-palette" @onclick:stopPropagation>
            <button class="modal-close command-close" @onclick="CloseCommandPalette" aria-label="Close command menu">×</button>
            <div class="command-search"><span>⌘</span><input placeholder="@T("Jump to…", "Springe zu…")" @bind="commandQuery" @bind:event="oninput" autofocus /></div>
            <div class="command-results">
                @foreach (var command in FilteredCommands)
                {
                    <a href="@command.Url" @onclick="CloseCommandPalette"><span>@command.Icon</span><div><strong>@T(command.En, command.De)</strong><small>@command.Hint</small></div><kbd>↵</kbd></a>
                }
            </div>
            <small class="command-footer">ESC @T("to close", "zum Schließen") · ↑↓ @T("to navigate", "zum Navigieren")</small>
        </div>
    </div>
}

@code {
    private bool isDark;
    private bool isGerman;
    private bool menuOpen;
    private bool commandPaletteOpen;
    private bool emailCopied;
    private bool isProjectDragging;
    private string commandQuery = "";
    private string activeFilter = "all";
    private string selectedRole = "software";
    private int activeProjectIndex;
    private double projectDragStartX;
    private double projectDragOffset;
    private RoleFit SelectedRole => RoleFits.First(r => r.Key == selectedRole);
    private string[] SelectedEvidence => isGerman ? SelectedRole.EvidenceDe : SelectedRole.EvidenceEn;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        isDark = await JS.InvokeAsync<bool>("portfolio.isDark");
        await JS.InvokeVoidAsync("portfolio.initExperience");
        StateHasChanged();
    }

    private string T(string en, string de) => isGerman ? de : en;
    private void ToggleLanguage() => isGerman = !isGerman;
    private void ToggleMenu() => menuOpen = !menuOpen;
    private void CloseMenu() => menuOpen = false;
    private void OpenCommandPalette() { commandPaletteOpen = true; commandQuery = ""; }
    private void CloseCommandPalette() => commandPaletteOpen = false;
    private void SelectRole(string key) => selectedRole = key;
    private void ApplySelectedRoleFilter()
    {
        activeFilter = SelectedRole.ProjectFilter;
        activeProjectIndex = 0;
        projectDragOffset = 0;
        isProjectDragging = false;
    }
    private async Task SetProjectFilter(string key)
    {
        activeFilter = key;
        activeProjectIndex = 0;
        isProjectDragging = false;
        projectDragOffset = 0;
        await Task.CompletedTask;
    }

    private void MoveProject(int direction)
    {
        var count = FilteredProjects.Count();
        if (count == 0) return;
        activeProjectIndex = (activeProjectIndex + direction + count) % count;
        projectDragOffset = 0;
    }

    private void SetActiveProject(int index)
    {
        activeProjectIndex = index;
        projectDragOffset = 0;
    }

    private int GetProjectOffset(int index, int count)
    {
        if (count == 0) return 0;
        var offset = index - activeProjectIndex;
        if (offset > count / 2) offset -= count;
        if (offset < -count / 2) offset += count;
        return Math.Clamp(offset, -3, 3);
    }

    private void StartProjectDrag(PointerEventArgs e)
    {
        isProjectDragging = true;
        projectDragStartX = e.ClientX;
        projectDragOffset = 0;
    }

    private void MoveProjectDrag(PointerEventArgs e)
    {
        if (!isProjectDragging) return;
        projectDragOffset = Math.Clamp((e.ClientX - projectDragStartX) / 180, -1, 1);
    }

    private void EndProjectDrag(PointerEventArgs e)
    {
        if (!isProjectDragging) return;
        var delta = e.ClientX - projectDragStartX;
        isProjectDragging = false;
        projectDragOffset = 0;

        if (Math.Abs(delta) < 55) return;
        MoveProject(delta < 0 ? 1 : -1);
    }

    private void CancelProjectDrag()
    {
        isProjectDragging = false;
        projectDragOffset = 0;
    }

    private async Task ToggleTheme()
    {
        isDark = !isDark;
        await JS.InvokeVoidAsync("portfolio.setTheme", isDark);
    }

    private async Task CopyEmail()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", "Rohitsuryaas21@gmail.com");
        emailCopied = true;
        await Task.Delay(1800);
        emailCopied = false;
    }

    private IEnumerable<PortfolioProject> FilteredProjects => activeFilter == "all" ? Projects : Projects.Where(p => p.Category.Equals(activeFilter, StringComparison.OrdinalIgnoreCase));
    private IEnumerable<Command> FilteredCommands => Commands.Where(c => string.IsNullOrWhiteSpace(commandQuery) || c.En.Contains(commandQuery, StringComparison.OrdinalIgnoreCase) || c.Hint.Contains(commandQuery, StringComparison.OrdinalIgnoreCase));

    private static readonly (string Id, string En, string De)[] NavItems =
    [
        ("about", "About", "Über mich"), ("work", "Work", "Projekte"), ("lab", "Fit", "Fit"),
        ("experience", "Experience", "Erfahrung"), ("education", "Education", "Ausbildung"), ("contact", "Contact", "Kontakt")
    ];

    private static readonly (string Key, string En, string De)[] ProjectFilters =
    [
        ("all", "All work", "Alle"), ("Embedded Systems", "Embedded systems", "Embedded Systems"), ("Research", "Research", "Forschung"), ("Machine Learning", "Machine learning", "Machine Learning"), ("Data Engineering", "Data engineering", "Data Engineering")
    ];

    private static readonly Principle[] Principles =
    [
        new("01", "Measure the outcome", "Ergebnisse messen", "A model is only useful when it improves a decision, process, or product.", "Ein Modell ist nur wertvoll, wenn es Entscheidungen, Prozesse oder Produkte verbessert."),
        new("02", "Build for production", "Für Produktion bauen", "Clean APIs, observable systems, maintainable code, and deliberate trade-offs.", "Saubere APIs, beobachtbare Systeme, wartbarer Code und bewusste Trade-offs."),
        new("03", "Explain the complexity", "Komplexität erklären", "Clear communication turns technical depth into shared understanding.", "Klare Kommunikation macht technische Tiefe gemeinsam verständlich.")
    ];

    private static readonly PortfolioProject[] Projects =
    [
        new("01", "Research", "Windmill Pitch Prediction", "Windkraft-Pitch-Vorhersage",
            "An adaptive prediction system that turns live turbine data into more precise pitch control and measurable power gains.",
            "Ein adaptives Vorhersagesystem, das Live-Turbinendaten in präzisere Pitch-Steuerung und messbare Leistungssteigerung übersetzt.",
            ["XGBoost", "Time Series", "Feature Engineering", "Python"],
            "https://github.com/srohitsuryaa21/windmill-pitch-prediction", "https://doi.org/10.1109/ICEMCE57940.2023.10433983",
            "+21%", "POWER OUTPUT", "Pitch-control errors reduced turbine efficiency and created unstable output.", "Engineered 26 temporal features and combined XGBoost prediction with a residual-correction layer.", "96% prediction accuracy, error reduced from 8.6% to 2.3%, and power output increased by 21%.", "visual-wind"),
        new("02", "Data Engineering", "Supply Chain Intelligence", "Supply-Chain-Intelligence",
            "An end-to-end analytics pipeline for 100,000+ e-commerce transactions, joining forecasting, inventory optimization, delivery analytics, and seller risk.",
            "Eine End-to-End-Analytics-Pipeline für über 100.000 E-Commerce-Transaktionen mit Prognose, Bestandsoptimierung und Risikobewertung.",
            ["SARIMA", "XGBoost", "Plotly Dash", "Python"],
            "https://github.com/srohitsuryaa21/supply-chain-forecasting", null,
            "18.5%", "FORECAST MAPE", "Fragmented operational data made demand, delivery, and seller risk difficult to act on.", "Built a staged forecasting benchmark, EOQ optimization, risk scoring, and interactive decision dashboard.", "Sub-20% benchmark MAPE, 92.1% on-time analysis across 110,123 orders, and risk scores for 881 sellers.", "visual-supply"),
        new("03", "Research", "DeFi Farmer Platform", "DeFi-Plattform für Landwirte",
            "A transparent agricultural finance system using smart contracts to automate loans, payments, insurance, and supply-chain traceability.",
            "Ein transparentes Agrarfinanzsystem mit Smart Contracts für Kredite, Zahlungen, Versicherungen und Lieferketten.",
            ["Ethereum", "Solidity", "Web3.py", "Smart Contracts"],
            "https://github.com/srohitsuryaa21/defi_Farmer_Platform", "https://doi.org/10.1109/ICSCSS60660.2024.10625462",
